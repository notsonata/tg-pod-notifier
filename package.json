    "printify:webhooks": "tsx scripts/register-printify-webhooks.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.2.1",
    "grammy": "^1.36.3",
    "node-cron": "^4.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
