# Telegram bot token from BotFather.
# Example: 123456789:AA...
TELEGRAM_BOT_TOKEN=

# Telegram group chat ID that the bot is allowed to respond to.
# The bot will ignore DMs and all other groups.
# Get this by adding the bot to the group, sending a message, then calling:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# Group IDs are usually negative, often like -1001234567890.
AUTHORIZED_TELEGRAM_CHAT_ID=

# Public HTTPS base URL used for provider webhooks.
# This must match the hostname you publish through Cloudflare.
# Example: https://bot.example.com
PUBLIC_WEBHOOK_BASE_URL=

# Cloudflare Tunnel token for a remotely-managed tunnel.
# Create the tunnel in the Cloudflare dashboard, add a hostname, then copy the token.
# If you do not want Docker to start cloudflared automatically, leave this empty
# and run only the `app` service.
CLOUDFLARE_TUNNEL_TOKEN=

# Gelato API key used to refresh known Gelato orders and resolve webhook events.
# Get this from your Gelato account/API settings.
GELATO_API_KEY=

# Printify API token used to list and refresh orders for the configured shop.
# Get this from your Printify account/API settings.
PRINTIFY_API_TOKEN=

# Printify shop ID for the one shop this bot monitors in v1.
# Use the numeric or string shop ID from Printify.
PRINTIFY_SHOP_ID=

# Local SQLite database path inside the app container or local workspace.
# Keep this under ./data so Docker persistence works as expected.
DATABASE_PATH=./data/tg-notifier.sqlite

# Local HTTP port the Fastify server listens on.
# Docker maps this same port on the host.
PORT=38127

# IANA timezone name for daily digest scheduling.
# Examples: UTC, Asia/Manila, America/Los_Angeles
DEFAULT_TIMEZONE=UTC

# Default digest hour in 24-hour time when the settings row is first created.
# Example: 9 means 09:00 in the configured timezone.
DEFAULT_DIGEST_HOUR=9

# Default digest minute when the settings row is first created.
# Example: 0 means the digest runs on the hour.
DEFAULT_DIGEST_MINUTE=0
